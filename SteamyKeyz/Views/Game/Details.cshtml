@model SteamyKeyz.ViewModels.GameDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

@if (TempData["SuccessMessage"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <!-- ── Cover Image ────────────────────────────────────────── -->
    <div class="col-md-4 mb-4">
        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded shadow"
             style="width: 100%; max-height: 400px; object-fit: cover;"
             onerror="this.outerHTML='<div class=\'rounded bg-secondary d-flex align-items-center justify-content-center text-white\' style=\'height:300px\'><span class=\'display-1\'>🎮</span></div>'" />
    </div>

    <!-- ── Game Info ──────────────────────────────────────────── -->
    <div class="col-md-8">
        <h1 class="mb-2">@Model.Title</h1>

        <div class="text-muted mb-3">
            <span class="me-3"><strong>Developer:</strong> @Model.Developer</span>
            <span class="me-3"><strong>Publisher:</strong> @Model.Publisher</span>
            @if (Model.ReleaseDate.HasValue)
            {
                <span><strong>Released:</strong> @Model.ReleaseDate.Value.ToString("dd MMM yyyy")</span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="lead mb-4">@Model.Description</p>
        }

        <!-- ── Platform Pricing & Add to Cart ─────────────────── -->
        <h5 class="mb-3">Available Platforms</h5>

        @if (Model.Platforms.Count == 0)
        {
            <div class="alert alert-secondary">
                This game is not currently available on any platform.
            </div>
        }
        else
        {
            <div class="list-group mb-4">
                @foreach (var platform in Model.Platforms)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                           
                            <strong>@platform.PlatformName</strong>

                            @if (platform.AvailableKeys > 0)
                            {
                                <span class="badge bg-success ms-2">@platform.AvailableKeys in stock</span>
                            }
                            else
                            {
                                <span class="badge bg-danger ms-2">Out of stock</span>
                            }
                        </div>

                        <div class="d-flex align-items-center gap-3">
                            <span class="fw-bold fs-5 text-success">@platform.Price.ToString("C")</span>

                            @if (platform.AvailableKeys > 0)
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                    <input type="hidden" name="gameId" value="@Model.Id" />
                                    <input type="hidden" name="platformId" value="@platform.PlatformId" />
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        Add to Cart
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary btn-sm" disabled>
                                    Unavailable
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <!-- ── Admin Actions ──────────────────────────────────── -->
        @if (User.IsInRole("Admin"))
        {
            <hr />
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
            </div>
        }
    </div>
</div>

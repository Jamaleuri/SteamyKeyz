@model Game

@{
    ViewData["Title"] = $"Delete – {Model.Title}";
}

<h1 class="text-danger">Delete Game</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="border border-danger rounded p-4">
            <h4 class="mb-3">Are you sure you want to delete this game?</h4>
            <p>This will permanently remove the game, all associated platform pricing, keys, and cart items.</p>

            <dl class="row mb-0">
                <dt class="col-sm-4">Title</dt>
                <dd class="col-sm-8"><strong>@Model.Title</strong></dd>

                <dt class="col-sm-4">Developer</dt>
                <dd class="col-sm-8">@Model.Developer</dd>

                <dt class="col-sm-4">Publisher</dt>
                <dd class="col-sm-8">@Model.Publisher</dd>

                @if (Model.ReleaseDate.HasValue)
                {
                    <dt class="col-sm-4">Release Date</dt>
                    <dd class="col-sm-8">@Model.ReleaseDate.Value.ToString("dd MMM yyyy")</dd>
                }

                @if (Model.GamePlatforms.Any())
                {
                    <dt class="col-sm-4">Platforms</dt>
                    <dd class="col-sm-8">
                        @foreach (var gp in Model.GamePlatforms)
                        {
                            <span class="badge bg-secondary me-1">@gp.Platform.Name</span>
                        }
                    </dd>
                }
            </dl>

            <hr />

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Yes, Delete This Game</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>

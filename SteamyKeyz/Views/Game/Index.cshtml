@model SteamyKeyz.ViewModels.GameIndexViewModel

@{
    ViewData["Title"] = "Games";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Games</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Mitarbeiter"))
    {
        <a asp-action="Create" class="btn btn-success">+ Add Game</a>
    }
</div>

@if (TempData["SuccessMessage"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ── Filters ─────────────────────────────────────────────────── -->
<form method="get" asp-action="Index" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="text" name="search" value="@Model.Search" class="form-control"
               placeholder="Search by title, developer, publisher..." />
    </div>
    <div class="col-md-3">
        <select name="platformId" class="form-select">
            <option value="">All Platforms</option>
            @foreach (var p in Model.Platforms)
            {
                <option value="@p.Id" selected="@(Model.PlatformId == p.Id)">@p.Name</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="sortBy" class="form-select">
            <option value="title_asc" selected="@(Model.SortBy == "title_asc" || Model.SortBy == null)">Title A–Z</option>
            <option value="title_desc" selected="@(Model.SortBy == "title_desc")">Title Z–A</option>
            <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Price: Low to High</option>
            <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Price: High to Low</option>
            <option value="newest" selected="@(Model.SortBy == "newest")">Newest First</option>
            <option value="oldest" selected="@(Model.SortBy == "oldest")">Oldest First</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
</form>

<!-- ── Game Cards Grid ────────────────────────────────────────── -->
@if (Model.Games.Count == 0)
{
    <div class="text-center py-5 text-muted">
        <h4>No games found</h4>
        <p>Try adjusting your search or filters.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var game in Model.Games)
        {
            <div class="col">
                <a asp-action="Details" asp-route-id="@game.Id" class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@game.ImageUrl" class="card-img-top" alt="@game.Title"
                             style="height: 200px; object-fit: cover;"
                             onerror="this.outerHTML='<div class=\'card-img-top bg-secondary d-flex align-items-center justify-content-center text-white\' style=\'height:200px\'><span class=\'fs-4\'>🎮</span></div>'" />
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title mb-1">@game.Title</h6>
                            <small class="text-muted mb-2">@game.Developer</small>

                            @if (game.PlatformNames.Any())
                            {
                                <div class="mb-2">
                                    @foreach (var platform in game.PlatformNames)
                                    {
                                        <span class="badge bg-secondary me-1">@platform</span>
                                    }
                                </div>
                            }

                            <div class="mt-auto">
                                @if (game.LowestPrice.HasValue)
                                {
                                    <span class="fw-bold text-success fs-5">
                                        @game.LowestPrice.Value.ToString("C")
                                    </span>
                                    @if (game.PlatformNames.Count > 1)
                                    {
                                        <small class="text-muted"> +</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not available</span>
                                }
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    <!-- ── Pagination ─────────────────────────────────────────── -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Game pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@Model.Search"
                       asp-route-platformId="@Model.PlatformId"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-page="@(Model.CurrentPage - 1)">
                        &laquo; Prev
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-platformId="@Model.PlatformId"
                           asp-route-sortBy="@Model.SortBy"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-search="@Model.Search"
                       asp-route-platformId="@Model.PlatformId"
                       asp-route-sortBy="@Model.SortBy"
                       asp-route-page="@(Model.CurrentPage + 1)">
                        Next &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    }
}

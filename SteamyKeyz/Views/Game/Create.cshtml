@model SteamyKeyz.ViewModels.GameFormViewModel

@{
    ViewData["Title"] = "Add Game";
}

<h1>Add Game</h1>
<hr />

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" autofocus />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Developer" class="form-label"></label>
                    <input asp-for="Developer" class="form-control" />
                    <span asp-validation-for="Developer" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Publisher" class="form-label"></label>
                    <input asp-for="Publisher" class="form-control" />
                    <span asp-validation-for="Publisher" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="ReleaseDate" class="form-label"></label>
                <input asp-for="ReleaseDate" class="form-control" type="date" />
                <span asp-validation-for="ReleaseDate" class="text-danger"></span>
            </div>

            <!-- ── Cover Image Upload ─────────────────────────── -->
            <div class="mb-3">
                <label asp-for="CoverImage" class="form-label"></label>
                <input asp-for="CoverImage" class="form-control" type="file"
                       accept=".jpg,.jpeg,.png,.webp" id="coverInput" />
                <span asp-validation-for="CoverImage" class="text-danger"></span>
                <small class="text-muted d-block mt-1">
                    Accepted formats: JPG, PNG, WebP. Max 5 MB.
                </small>

                <div id="coverPreviewContainer" class="mt-2" style="display: none;">
                    <img id="coverPreview" class="rounded shadow-sm"
                         style="max-height: 200px; max-width: 100%; object-fit: cover;" alt="Preview" />
                </div>
            </div>

            <!-- ── Platform Prices ────────────────────────────── -->
            <h5 class="mt-4 mb-3">Platform Pricing</h5>
            <p class="text-muted small">Select which platforms this game is available on and set a price for each.</p>

            @for (int i = 0; i < Model.PlatformPrices.Count; i++)
            {
                <input type="hidden" name="PlatformPrices[@i].PlatformId" value="@Model.PlatformPrices[i].PlatformId" />
                <input type="hidden" name="PlatformPrices[@i].PlatformName" value="@Model.PlatformPrices[i].PlatformName" />

                <div class="card mb-2">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="form-check">
                                <input type="checkbox"
                                       class="form-check-input platform-toggle"
                                       name="PlatformPrices[@i].IsSelected"
                                       value="true"
                                       id="platform_@i"
                                       data-target="price_@i"
                                       @(Model.PlatformPrices[i].IsSelected ? "checked" : "") />
                                <label class="form-check-label fw-semibold" for="platform_@i">
                                    @Model.PlatformPrices[i].PlatformName
                                </label>
                            </div>
                            <div class="ms-auto" style="width: 160px;">
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text">€</span>
                                    <input type="number"
                                           class="form-control"
                                           name="PlatformPrices[@i].Price"
                                           id="price_@i"
                                           value="@Model.PlatformPrices[i].Price"
                                           step="0.01" min="0"
                                           @(Model.PlatformPrices[i].IsSelected ? "" : "disabled") />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="mt-4">
                <button type="submit" class="btn btn-success">Create Game</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('.platform-toggle').forEach(function (cb) {
            cb.addEventListener('change', function () {
                var priceInput = document.getElementById(this.dataset.target);
                priceInput.disabled = !this.checked;
                if (!this.checked) priceInput.value = '0';
            });
        });

        document.getElementById('coverInput').addEventListener('change', function (e) {
            var container = document.getElementById('coverPreviewContainer');
            var preview = document.getElementById('coverPreview');
            var file = e.target.files[0];
            if (file) {
                var reader = new FileReader();
                reader.onload = function (ev) {
                    preview.src = ev.target.result;
                    container.style.display = 'block';
                };
                reader.readAsDataURL(file);
            } else {
                container.style.display = 'none';
                preview.src = '';
            }
        });
    </script>
}

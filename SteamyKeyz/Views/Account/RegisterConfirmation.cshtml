@{
    ViewData["Title"] = "Check Your Email";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center py-5">
        <div style="font-size: 4rem;">📧</div>
        <h1 class="mt-3">Check Your Email</h1>
        <p class="text-muted mt-3">
            We've sent a confirmation link to your email address.
            Please click the link to activate your account.
        </p>

        <div class="alert alert-light mt-4">
            <strong>Didn't receive it?</strong> Check your spam folder, or
            <a href="#" onclick="document.getElementById('resendForm').submit(); return false;">
                click here to resend
            </a>.
        </div>

        <p class="mt-4">
            <a asp-action="Login" class="btn btn-outline-primary">Go to Login</a>
        </p>
    </div>
</div>@{

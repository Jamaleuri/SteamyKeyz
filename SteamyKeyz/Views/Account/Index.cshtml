@model SteamyKeyz.ViewModels.AccountPageViewModel

@{
    ViewData["Title"] = "My Account";
}

<h1>My Account</h1>
<p class="text-muted mb-4">
    Signed in as <strong>@Model.Username</strong> (@Model.Email) &mdash;
    member since @Model.MemberSince.ToString("MMMM yyyy")
</p>

@if (TempData["SuccessMessage"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ── Tab Navigation ─────────────────────────────────────────── -->
<ul class="nav nav-tabs mb-4" id="accountTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.ActiveTab == "games" ? "active" : "")"
                id="games-tab" data-bs-toggle="tab" data-bs-target="#games"
                type="button" role="tab" aria-controls="games"
                aria-selected="@(Model.ActiveTab == "games" ? "true" : "false")">
            Owned Games
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(Model.ActiveTab == "password" ? "active" : "")"
                id="password-tab" data-bs-toggle="tab" data-bs-target="#password"
                type="button" role="tab" aria-controls="password"
                aria-selected="@(Model.ActiveTab == "password" ? "true" : "false")">
            Change Password
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link text-danger @(Model.ActiveTab == "delete" ? "active" : "")"
                id="delete-tab" data-bs-toggle="tab" data-bs-target="#delete"
                type="button" role="tab" aria-controls="delete"
                aria-selected="@(Model.ActiveTab == "delete" ? "true" : "false")">
            Delete Account
        </button>
    </li>
</ul>

<!-- ── Tab Content ────────────────────────────────────────────── -->
<div class="tab-content" id="accountTabContent">

    <!-- ▸ Owned Games ─────────────────────────────────────────── -->
    <div class="tab-pane fade @(Model.ActiveTab == "games" ? "show active" : "")"
         id="games" role="tabpanel" aria-labelledby="games-tab">

        @if (Model.OwnedGames.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <h5>No games yet</h5>
                <p>Games you purchase will appear here.</p>
                <a asp-controller="Game" asp-action="Index" class="btn btn-outline-primary">
                    Browse Games
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px;"></th>
                            <th>Title</th>
                            <th>Platform</th>
                            <th>Purchased</th>
                            <th class="text-end">Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var game in Model.OwnedGames)
                        {
                            <tr>
                                <td>
                                    <img src="@game.ImageUrl" alt="@game.Title"
                                         class="rounded" style="width:48px; height:48px; object-fit:cover;"
                                         onerror="this.style.display='none'" />
                                </td>
                                <td><strong>@game.Title</strong></td>
                                <td>@game.Platform</td>
                                <td>@game.PurchasedAt.ToString("dd MMM yyyy")</td>
                                <td class="text-end">@game.PricePaid.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    
    <!-- ▸ Change Password ─────────────────────────────────────── -->
    <div class="tab-pane fade @(Model.ActiveTab == "password" ? "show active" : "")"
         id="password" role="tabpanel" aria-labelledby="password-tab">

        <div class="row">
            <div class="col-md-5">
                <h5 class="mb-3">Change Password</h5>

                <form asp-action="ChangePassword" method="post">
                    <div class="mb-3">
                        <label asp-for="ChangePassword.CurrentPassword" class="form-label"></label>
                        <input asp-for="ChangePassword.CurrentPassword" class="form-control" />
                        <span asp-validation-for="ChangePassword.CurrentPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ChangePassword.NewPassword" class="form-label"></label>
                        <input asp-for="ChangePassword.NewPassword" class="form-control" />
                        <span asp-validation-for="ChangePassword.NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ChangePassword.ConfirmNewPassword" class="form-label"></label>
                        <input asp-for="ChangePassword.ConfirmNewPassword" class="form-control" />
                        <span asp-validation-for="ChangePassword.ConfirmNewPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Update Password</button>
                </form>
            </div>
        </div>
    </div>

    <!-- ▸ Delete Account ──────────────────────────────────────── -->
    <div class="tab-pane fade @(Model.ActiveTab == "delete" ? "show active" : "")"
         id="delete" role="tabpanel" aria-labelledby="delete-tab">

        <div class="row">
            <div class="col-md-5">
                <div class="border border-danger rounded p-4">
                    <h5 class="text-danger mb-3">Delete Your Account</h5>
                    <p>
                        This action is <strong>permanent</strong>. Your account will be deactivated,
                        your personal information removed, and your shopping cart cleared.
                        Purchase history will be retained for legal purposes but will no longer
                        be linked to your identity.
                    </p>

                    <form asp-action="DeleteAccount" method="post" id="deleteAccountForm">
                        <div class="mb-3">
                            <label asp-for="DeleteAccount.Password" class="form-label"></label>
                            <input asp-for="DeleteAccount.Password" class="form-control" />
                            <span asp-validation-for="DeleteAccount.Password" class="text-danger"></span>
                        </div>

                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                            Delete My Account
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Delete Confirmation Modal ──────────────────────────────── -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger" id="confirmDeleteLabel">Confirm Account Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to permanently delete your account? This cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Yes, Delete My Account</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('confirmDeleteBtn')?.addEventListener('click', function () {
            document.getElementById('deleteAccountForm').submit();
        });
    </script>
}

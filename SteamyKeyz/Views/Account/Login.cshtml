@model SteamyKeyz.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<h1>Log In</h1>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div asp-validation-summary="All" class="text-danger"></div>
            @if (ViewBag.UnconfirmedUserId != null)
            {
                <div class="alert alert-warning">
                    <strong>Email not confirmed.</strong>
                    Didn't get the email?
                    <form asp-action="ResendConfirmation" method="post" class="d-inline">
                        <input type="hidden" name="userId" value="@ViewBag.UnconfirmedUserId" />
                        <button type="submit" class="btn btn-link p-0 align-baseline">
                            Resend confirmation email
                        </button>
                    </form>
                </div>
            }
            <div class="mb-3">
                <label asp-for="UsernameOrEmail" class="form-label"></label>
                <input asp-for="UsernameOrEmail" class="form-control" autofocus />
                <span asp-validation-for="UsernameOrEmail" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary">Log In</button>
        </form>

        <p class="mt-3">
            Don't have an account?
            <a asp-action="Register">Register here</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

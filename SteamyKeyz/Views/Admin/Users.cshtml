@model IEnumerable<User>
@{
    ViewData["Title"] = "User Management";
    var roles = ViewBag.Roles as List<Role> ?? new List<Role>();
    var search = ViewBag.Search as string;
    var roleId = ViewBag.RoleId as int?;
    var isActive = ViewBag.IsActive as bool?;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-people-fill me-2"></i>User Management</h1>
    <span class="badge bg-secondary fs-6">@Model.Count() users</span>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>Done!</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Error:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Users" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Search (username or email)</label>
                <input type="text" name="search" class="form-control" value="@search"
                       placeholder="e.g. john or john@@example.com" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Role</label>
                <select name="roleId" class="form-select">
                    <option value="">All Roles</option>
                    @foreach (var role in roles)
                    {
                        <option value="@role.Id" selected="@(roleId == role.Id)">@role.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="isActive" class="form-select">
                    <option value="">All</option>
                    <option value="true" selected="@(isActive == true)">Active</option>
                    <option value="false" selected="@(isActive == false)">Suspended</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<!-- User Table -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var user in Model)
            {
                <tr class="@(!user.IsActive ? "table-warning" : "")">
                    <td><code>@user.Id</code></td>
                    <td><strong>@user.Username</strong></td>
                    <td>@user.Email</td>
                    <td>
                        <span class="badge @(user.Role.Name switch
                                           {
                                               "Admin" => "bg-danger", 
                                               "Mitarbeiter" => "bg-warning text-dark", 
                                               _ => "bg-info text-dark"
                                           })">                            
                            @user.Role.Name
                        </span>
                    </td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Suspended</span>
                        }
                    </td>
                    <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <!-- Role Change Dropdown -->
                            <form method="post" asp-action="ChangeRole" class="d-inline">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <div class="input-group input-group-sm" style="width: 180px;">
                                    <select name="roleId" class="form-select form-select-sm">
                                        @foreach (var role in roles)
                                        {
                                            <option value="@role.Id" selected="@(user.RoleId == role.Id)">@role.Name</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-outline-primary btn-sm"
                                            title="Change role"
                                            onclick="return confirm('Change role for @user.Username?');">
                                        Set
                                    </button>
                                </div>
                            </form>

                            <!-- Suspend / Activate Toggle -->
                            <form method="post" asp-action="ToggleActive" asp-route-id="@user.Id">
                                @if (user.IsActive)
                                {
                                    <button type="submit" class="btn btn-outline-warning btn-sm"
                                            title="Suspend user"
                                            onclick="return confirm('Suspend @user.Username?');">
                                        Suspend
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-outline-success btn-sm"
                                            title="Activate user"
                                            onclick="return confirm('Activate @user.Username?');">
                                        Activate
                                    </button>
                                }
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        No users found matching your filters.
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
